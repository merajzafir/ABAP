FORM transfer_retiretoai .

  TYPES : BEGIN OF ty_cc,
            cc TYPE kostl,
          END OF ty_cc.

  DATA: lt_cc TYPE TABLE OF ty_cc,
        ls_cc TYPE ty_cc.

  DATA: ls_ai_retire TYPE zai_tran_header,
        lt_data      TYPE zfi_ai_tt_data,
        ls_data      TYPE zfi_ai_st_data.

  DATA: wa_custom TYPE zai_s_item,
        it_custom TYPE TABLE OF zai_s_item.

  DATA : lv_host   TYPE string,
         lv_length TYPE string.

  DATA : gc_http_status   TYPE string VALUE '~status_code',
         gc_status_reason TYPE string VALUE '~status_reason',
         gc_content_len   TYPE string VALUE '~content-length',
         gc_location      TYPE string VALUE 'location',
         gc_content_type  TYPE string VALUE 'content-type'.

  DATA: gv_key_id  TYPE string,
        gv_key_sec TYPE string,
        gv_url     TYPE string VALUE 'https://api.assetinfinity.IO/api/transfermultipleasset'.

  IF gt_msgout IS NOT INITIAL.

    SELECT * FROM zfi_ai_retire_tb
      INTO TABLE @DATA(lt_assetlist)
      FOR ALL ENTRIES IN @gt_msgout
      WHERE assetmaino EQ @gt_msgout-assetmaino.

    IF lt_assetlist IS NOT INITIAL.

      LOOP AT lt_assetlist INTO DATA(ls_al).

        IF NOT line_exists( lt_cc[ cc = ls_al-cost_center ] ).

          ls_cc-cc = ls_al-cost_center.
          APPEND ls_cc TO lt_cc.
          CLEAR ls_cc.

        ENDIF.

      ENDLOOP.

    ENDIF.

  ENDIF.

  LOOP AT lt_cc INTO ls_cc.

    ls_ai_retire-statusid = '3075'.

    CLEAR ls_al.

    LOOP AT lt_assetlist INTO ls_al WHERE cost_center = ls_cc-cc.

      ls_data-assetcode = ls_al-assetmaino.

      SELECT SINGLE txt50 FROM anla
        INTO @DATA(lv_desc)
        WHERE anln1 = @ls_al-assetmaino.

      ls_data-assetname = lv_desc.

      ls_data-currentlocation = ls_cc-cc.
      ls_data-status = SWITCH #( ls_al-process_code WHEN 2 THEN 'Retire' WHEN 3 THEN 'Not Retire').
      APPEND ls_data TO lt_data.
      CLEAR ls_data.

    ENDLOOP.

    MOVE-CORRESPONDING lt_data TO ls_ai_retire-data.

    it_custom = VALUE #(
                        ( fieldname = 'column11'  fieldvalue = 'null' fieldvalueid = 'null' controlid = 'null' )
                        ( fieldname = 'column2'   fieldvalue = 'null' fieldvalueid = 'null' controlid = '300115' )
                        ( fieldname = 'column6'   fieldvalue = '0' fieldvalueid = 'null' controlid = 'null' )
                        ( fieldname = 'column9'   fieldvalue = 'null' fieldvalueid = 'null' controlid = 'null' )
                        ( fieldname = 'column7'   fieldvalue = '0' fieldvalueid = 'null' controlid = 'null' )
                        ( fieldname = 'column8'   fieldvalue = 'null' fieldvalueid = 'null' controlid = 'null' )
                        ( fieldname = 'column13'  fieldvalue = '' fieldvalueid = 'null' controlid = '300123' )
                        ).

    ls_ai_retire-custom = it_custom.

*  ENDLOOP.

*==>preparing to send
    cl_http_client=>create_by_url(
      EXPORTING
        url                =     gv_url
      IMPORTING
        client             =     DATA(lo_http_client)
      EXCEPTIONS
        argument_not_found = 1
        plugin_not_active  = 2
        internal_error     = 3
        OTHERS             = 4 ).
    IF sy-subrc <> 0.
*==>If exception is occured then close communication
      lo_http_client->close( ).
    ENDIF.

*==>If lo_http_client is bound then only proceed further
    CHECK lo_http_client IS BOUND.

    DATA(lo_rest_client) = NEW cl_rest_http_client( io_http_client = lo_http_client ).

*==>Set HTTP Protocol Version 1.0
    lo_http_client->request->set_version( if_http_request=>co_protocol_version_1_0 ).

*==>Check lo_http_client, lo_rest_client are bound then only proceed further
    CHECK lo_http_client IS BOUND AND lo_rest_client IS BOUND.

*==>Pass Source Structure to JSON Serializer for converting into JSON format
    DATA(lo_json_serializer) = NEW cl_trex_json_serializer( ls_ai_retire  ).

*==>Check go_json_serializer is bound or not
    CHECK lo_json_serializer IS BOUND.

*==>Convert Source into JSON Format
    lo_json_serializer->serialize( ).
    DATA(lv_body) = lo_json_serializer->get_data( ).

*==>Update the JSON Structure Field Names as per target
    REPLACE ALL OCCURRENCES OF 'assetid:' IN lv_body WITH '"assetId":'.
    REPLACE ALL OCCURRENCES OF 'statusid:' IN lv_body WITH '"statusId":'.
    REPLACE ALL OCCURRENCES OF 'locationid:' IN lv_body WITH '"locationId":'.
    REPLACE ALL OCCURRENCES OF 'htfocuscatcher:' IN lv_body WITH '"htFocusCatcher":'.
    REPLACE ALL OCCURRENCES OF 'remarks:' IN lv_body WITH '"remarks":'.
    REPLACE ALL OCCURRENCES OF 'partnerid:' IN lv_body WITH '"partnerId":'.
    REPLACE ALL OCCURRENCES OF 'allotedto:' IN lv_body WITH '"allotedTo":'.
    REPLACE ALL OCCURRENCES OF 'uploadfiles:' IN lv_body WITH '"uploadFiles":'.
    REPLACE ALL OCCURRENCES OF 'projectid:' IN lv_body WITH '"projectId":'.
    REPLACE ALL OCCURRENCES OF 'latitude:' IN lv_body WITH '"latitude":'.
    REPLACE ALL OCCURRENCES OF 'longitude:' IN lv_body WITH '"longitude":'.
    REPLACE ALL OCCURRENCES OF 'assetreservationid:' IN lv_body WITH '"assetReservationId":'.
    REPLACE ALL OCCURRENCES OF 'requisitiondetailid:' IN lv_body WITH '"requisitionDetailId":'.
    REPLACE ALL OCCURRENCES OF 'blank:' IN lv_body WITH '"":'.
    REPLACE ALL OCCURRENCES OF 'transfercc:' IN lv_body WITH '"transferCC":'.
    REPLACE ALL OCCURRENCES OF 'data:' IN lv_body WITH '"data":'.
    REPLACE ALL OCCURRENCES OF 'assetcode:' IN lv_body WITH '"Asset Code":'.
    REPLACE ALL OCCURRENCES OF 'hsncode:' IN lv_body WITH '"HSN Code":'.
    REPLACE ALL OCCURRENCES OF 'assetname:' IN lv_body WITH '"Asset Name":'.
    REPLACE ALL OCCURRENCES OF 'sgst:' IN lv_body WITH '"SGST %":'.
    REPLACE ALL OCCURRENCES OF 'cgst:' IN lv_body WITH '"CGST %":'.
    REPLACE ALL OCCURRENCES OF 'igst:' IN lv_body WITH '"IGST %":'.
    REPLACE ALL OCCURRENCES OF 'currentlocation:' IN lv_body WITH '"Current Location":'.
    REPLACE ALL OCCURRENCES OF 'status:' IN lv_body WITH '"Status":'.
    REPLACE ALL OCCURRENCES OF 'custom:' IN lv_body WITH '"custom":'.
    REPLACE ALL OCCURRENCES OF 'fieldname:' IN lv_body WITH '"fieldName":'.
    REPLACE ALL OCCURRENCES OF 'fieldvalue:' IN lv_body WITH '"fieldValue":'.
    REPLACE ALL OCCURRENCES OF 'fieldvalueid:' IN lv_body WITH '"fieldValueId":'.
    REPLACE ALL OCCURRENCES OF 'controlid:' IN lv_body WITH '"controlId":'.

    CONDENSE lv_body NO-GAPS.

    DATA(lo_request) = lo_rest_client->if_rest_client~create_request_entity( ).

    CHECK lo_request IS BOUND.
*==>Set Content type
    lo_request->set_content_type( EXPORTING iv_media_type = if_rest_media_type=>gc_appl_json ).

*==>get entity in Text Format
    lo_request->set_string_data( iv_data = lv_body ).

    CONCATENATE 'Bearer eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1bmlxdWVfbmFtZSI6IjEzMjciLCJjb21wYW55IjoiQmxpbmtpdCIsImVtY'
           'WlsIjoiVXJ2YXNoaUBhc3NldGluZmluaXR5LmNvbSIsImRhdGVGb3JtYXQiOiJkZC9NTS95eXl5IGhoOm1tIHR0IiwidGltZVpvbmUiOiJJbmRpYSB'
           'TdGFuZGFyZCBUaW1lIiwiZGV2aWNlSWQiOiI4MDgwOTQ3OS00ODFiLTQxYmEtZDc2ZC1jM2I4MWNlNGJmZDQiLCJ1c2VyVHlwZUlkIjoiMiIsIm5iZ'
           'iI6MTc3MDcxOTU1OSwiZXhwIjoxOTI4Mzk5ODU5LCJpYXQiOjE3NzA3MTk1NTksImlzcyI6IkFzc2V0IEluZmluaXR5IiwiYXVkIjoiYXNzZXRpbmZ'
           'pbml0eS1jbGllbnRzIn0.KyN_q-D32yxAhLLNA0uERpBWSX_EBZHStZSOhk1ad9pg6poRa9DxtEUIyPZfG4-EthofMORHZmWGoGgeOsjB03rSujTT2'
           '5jlPz7i-lM_lr6mPi2TqjxPqPkSrnfnVSraFPOeKq-DHMrzFbPvdam77s9hwNqGDenD9xUW88TnUxh192A7Og0bNOQiqmszLOzvKT__JK31Cg9h1hbf0'
           'TM2ERhpgSLy-iXYIl5KOrSuMZCKpTiwmcVsO4lgRjANY1MKroxRxwTSg_z2fUn2CRB1WQMVyaZqHtFWLp1gZIE9D4HMDHtmgMJCS5oGH3ECGY1Vi5KIz'
           'ZgBzGhvgFobXT58JQ'
           INTO DATA(lv_auth).

*==>Set Header Field for Authorization
    lo_request->set_header_field( EXPORTING iv_name  = 'Authorization' iv_value = lv_auth ).

*==>Set Header Field for Content Type
    lo_request->set_header_field( EXPORTING iv_name  = 'content-Type' iv_value = 'application/json' ).

*==>Set Header Field for Accept
    lo_request->set_header_field( EXPORTING iv_name  = 'Accept' iv_value = '*/*' ).

    " Set Content-Length manually
    lv_length = strlen( lv_body ).
    lo_request->set_header_field( EXPORTING iv_name = 'Content-Length' iv_value = lv_length ).

    TRY.
*==>Post
        lo_rest_client->if_rest_resource~post( lo_request ).
      CATCH cx_rest_client_exception.
    ENDTRY.

*==>Collect POST method response
    DATA(lo_response)             = lo_rest_client->if_rest_client~get_response_entity( ).
    DATA(lv_http_status)          = lo_response->get_header_field( gc_http_status ).
    DATA(lv_reason)               = lo_response->get_header_field( gc_status_reason ).
    DATA(lv_content_length)       = lo_response->get_header_field( gc_content_len ).
    DATA(lv_location)             = lo_response->get_header_field( gc_location ).
    DATA(lv_content_type)         = lo_response->get_header_field( gc_content_type ).
    DATA(lv_response)             = lo_response->get_string_data( ).

    IF lv_http_status = '200'.

      DATA: lt_retire_log TYPE TABLE OF zfi_ai_retir_log,
            ls_retire_log TYPE zfi_ai_sale_log.

      LOOP AT lt_data ASSIGNING FIELD-SYMBOL(<fs_data>).

        ls_retire_log-datum = sy-datum.
        ls_retire_log-uzeit = sy-uzeit.
        ls_retire_log-assetmaino = <fs_data>-assetcode.
        ls_retire_log-reason = lv_response.
        ls_retire_log-http_status = lv_response.
        ls_retire_log-reason = lv_reason.

        INSERT zfi_ai_retir_log FROM ls_retire_log.
        CLEAR ls_retire_log.

      ENDLOOP.

    ELSE.

      LOOP AT lt_data ASSIGNING <fs_data>.

        ls_retire_log-datum = sy-datum.
        ls_retire_log-uzeit = sy-uzeit.
        ls_retire_log-assetmaino = <fs_data>-assetcode.
        ls_retire_log-reason = lv_response.
        ls_retire_log-http_status = 'FAIL'.
        ls_retire_log-reason = lv_reason.

        INSERT zfi_ai_retir_log FROM ls_retire_log.
        CLEAR ls_retire_log.

      ENDLOOP.

    ENDIF.

    CLEAR: lv_body, ls_ai_retire.
    REFRESH: lt_data, it_custom.

  ENDLOOP.

ENDFORM.
